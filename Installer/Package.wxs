<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="COM_BLAS.Installer" Manufacturer="Your Company Name" Version="0.0.1" UpgradeCode="PUT-GUID-HERE">
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed" />

    <Feature Id="Main">
      <ComponentGroupRef Id="Components" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="Components" Directory="INSTALLFOLDER">
      <Component>
        <!-- TODO: Install something more useful than this source code file itself -->
        <File Source="Package.wxs" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="!(Property.Manufacturer) !(Property.ProductName)" />
    </StandardDirectory>
  </Fragment>
</Wix>
